# Device/app state — never committed.
.obsidian/
.trash/
.DS_Store

# Runtime lock files (created lazily by knotica's mutation guard).
.knotica/locks/

# Live ingest dashboard journal (ephemeral progress; not part of the wiki audit trail).
.knotica/ingest-activity.jsonl

# Source-ingest worktrees (created lazily by a client-driven suggestion ingest;
# recoverable via `git worktree list` -- throwaway runtime state, not the wiki).
.knotica/worktrees/

# Eval bootstrap scratchpad (human review before freeze; never committed).
**/.knotica/datasets/golden.staging.jsonl

# NOTE: .knotica/ itself IS committed — it carries agent state (datasets/qa.jsonl, prompts/,
# compiled/) that is part of the wiki's versioned substrate. Do not ignore it.
